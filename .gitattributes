# Force LF for all shell scripts
*.sh text eol=lf

# Force LF for PowerShell scripts
*.ps1 text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf

# Force LF for Dockerfiles
Dockerfile text eol=lf
*.Dockerfile text eol=lf

# Optional: force LF for markdown and config files
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini text eol=lf
